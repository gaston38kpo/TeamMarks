{
    "manifest_version": 3,
    "name": "TeamMarks",
    "description": "Sync bookmark folders with your team via Supabase — keep everyone's bookmarks in sync, in real time.",
    "version": "0.1.0",
    "icons": {
        "16": "logo/favicon-16x16.png",
        "32": "logo/favicon-32x32.png",
        "48": "logo/favicon-48x48.png",
        "64": "logo/favicon-64x64.png",
        "128": "logo/favicon-128x128.png",
        "180": "logo/favicon-180x180.png",
        "256": "logo/favicon-256x256.png"
    },
    "options_page": "settings/settings.html",
    "action": {
        "default_title": "TeamMarks",
        "default_popup": "popup/popup.html"
    },
    "permissions": [
        "bookmarks",
        "storage",
        "identity",
        "alarms"
    ],
    "host_permissions": [
        "https://*.supabase.co/*"
    ],
    "oauth2": {
        "client_id": "240796616741-gc0le7idb3qk09jscjeo063su6fi9ljh.apps.googleusercontent.com",
        "scopes": ["openid", "email", "profile"]
    },
    "background": {
        "service_worker": "service-worker.js"
    }
}